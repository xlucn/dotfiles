" vim: ft=exrc syntax=vim commentstring=\"\ %s
" exrc, vi init file
" Note1: comment starts with "
" Note2: NO empty lines
"
""""""""""""""
" Vi Options "
""""""""""""""
"
" Automatically indent on the next line
set autoindent
" Auto save file after leaving the buffer
set autowrite
" Put buffer files in /tmp
set directory=/tmp
" Ignore case when searching
set ignorecase
" Show tab as ^I, EOL as $, literally. It's not good looking.
set nolist
" Modelines, search for 'vi:' for commands
set modelines
" Show line number, Arch Linux's package has a fix patch
set number
" Do repeat mapping, e.g., for g -> 1G
set remap
" Show messsage for edits exceeds this number of lines
set report=1
" Use bash for :shell command
set shell=/bin/bash
" Indent 4 spaces with autoindent, >> or <<
set shiftwidth=4
" Highlight the matching () {} when closing it.
set showmatch
" Show mode change
set showmode
" Tab 4 spaces
set tabstop=4
" Instant escape, otherwise keymapping will wait for 1 second
set notimeout
"
""""""""""""
" Mappings "
""""""""""""
"
" Mappings to quit, edit, save and more.
map g 1G
map ,q :q
map ,z :q!
map ,e :e
map ,w :w
map ,x :wq
map ,r :source ~/.config/ex/exrc
map  :source ~/.config/ex/exrc
"
" Delete and navigate in insert mode, better not use them.
" Make backspace to delete, with some bugs, e.g.:
"  not working well deleting the first char with more chars after
" map!  sa
" map!  sa
" Hacks for arrow heys, depends on timeout
" map! OA ka
" map! OB ja
" map! OC la
" map! OD ha
"
" Complete words, famous vi macros, modified from original below
map!  a.hbmmi?\<2h"zdt.@zywmx`mPlxa
map!  a.hbmmi/\<2h"zdt.@zywmx`mPlxa
" https://heather.cs.ucdavis.edu/~matloff/UnixAndC/Editors/ViIntro.html#tth_sEc4.1
" map!  a. hbmmi?\<2h"zdt.@zywmx`mP xi
" map!  a. hbmmi/\<2h"zdt.@zywmx`mP xi
"
" Join lines in a paragraph
" Modified from https://hea-www.harvard.edu/~fine/Tech/vi.html
map V 0ma}b:'a,.j}j
"
" Format mapping
" Original mapping from https://hea-www.harvard.edu/~fine/Tech/vi.html
" This will join the rest of the paragraph, break the line at the 72th column.
" You should keep pressing the key to format the whole paragraph.
map v 0ma}b:'a,.j072 ?  *dwi
"
" Execute current line
" Vi doesn't have command history, this can be used to try and modify commands
map  "ayy:@a
"
" Surround word with "/'/()/[]/{}
map " ebi"ea"
map ' ebi'ea'
map ) ebi(ea)
map ] ebi[ea]
map } ebi{ea}
" Delete surrounding "/'/()/[]/{}
map " F"xf"x
map ' F'xf'x
map ) F(xf)x
map ] F[xf]x
map } F{xf}x
"
