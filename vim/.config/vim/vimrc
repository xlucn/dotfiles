" IM Toggle {{{
" restore input method state when enter insert mode
let s:fcitx_cmd = executable('fcitx5-remote') ? 'fcitx5-remote' :
                \ executable('fcitx-remote') ? 'fcitx-remote' : v:null

function! IMDisable()
    if empty(s:fcitx_cmd)
        return
    endif
    let status = str2nr(system(s:fcitx_cmd))
    if status == 2
        call system(s:fcitx_cmd . ' -c')
    endif
endfunction

function! IMEnable()
    if empty(s:fcitx_cmd)
        return
    endif
    let status = str2nr(system(s:fcitx_cmd))
    if status == 2
        call system(s:fcitx_cmd . ' -o')
    endif
endfunction

augroup im_toggle
    autocmd!
    autocmd InsertEnter * call IMEnable()
    autocmd InsertLeave * call IMDisable()
augroup END
" }}}
