" Markdown preview{{{
function MarkdownPreviewToggle()
    if !exists('b:mdp_job')
        let b:mdp_job = job_start(['grip', '-b', expand("%:p")])
    else
        call job_stop(b:mdp_job)
        unlet b:mdp_job
    endif
